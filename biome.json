{
    "$schema": "https://biomejs.dev/schemas/2.2.4/schema.json",
    "assist": { "actions": { "source": { "organizeImports": "on" } } },
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true,
        "defaultBranch": "master"
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true
        }
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineEnding": "lf"
    }
}
